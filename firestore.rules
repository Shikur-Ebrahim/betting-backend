rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PUBLIC READS
    match /fixtures/{fixtureId} { allow read: if true; }
    match /live_matches/{fixtureId} { allow read: if true; }
    match /odds/{fixtureId} { allow read: if true; }
    match /match_stats/{fixtureId} { allow read: if true; }
    match /match_lineups/{fixtureId} { allow read: if true; }
    match /config/{docId} { allow read: if true; }
    
    // AUTHENTICATED USER DATA
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only backend updates balance
    }
    
    match /tickets/{ticketId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    match /deposits/{depositId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Handled by API
    }
    
    match /withdrawals/{withdrawId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Handled by API
    }

    match /sync_stats/{date} { allow read: if true; }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
